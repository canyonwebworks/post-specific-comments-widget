# @ pscw
#: post-specific-comments-widget.php:50
msgid "The most recent comments for a specific post"
msgstr "Los comentarios más recientes para una publicación específica"

# @ pscw
#: post-specific-comments-widget.php:54
msgid "Post-Specific Comments"
msgstr "Comentarios post-específicos"

# @ pscw
#: post-specific-comments-widget.php:84
msgid "Recent Comments"
msgstr "Comentarios recientes"

# @ pscw
#: post-specific-comments-widget.php:128
#, php-format
msgid "%1$s on %2$s"
msgstr "%1$s en %2$s"

# @ pscw
#: post-specific-comments-widget.php:132
#, php-format
msgid "<span class=\"recentcommentsauthor\">%1$s</span> said %2$s"
msgstr "<span class=\"recentcommentsauthor\">%1$s</span> dicho %2$s"

#: post-specific-comments-widget.php:140
#, php-format
msgid "<span class=\"recentcommentstitle\">%1$s</span> &ndash; %2$s"
msgstr "<span class=\"recentcommentstitle\">%1$s</span> – %2$s"

#: post-specific-comments-widget.php:221
msgid "Display Title"
msgstr "Mostrar el título"

# @ pscw
#: post-specific-comments-widget.php:224
msgid "Number of Comments to Show"
msgstr "Número de comentarios que se mostrarán"

# @ pscw
#: post-specific-comments-widget.php:227
msgid "Post/Page ID Number"
msgstr "Número de identificación de la publicación/página"

# @ pscw
#: post-specific-comments-widget.php:232
msgid "Comment Format"
msgstr "Formato de comentario"

#: post-specific-comments-widget.php:234
msgid "(Author) on (Post Title)"
msgstr "(Autor) en (Título posterior)"

#: post-specific-comments-widget.php:235
msgid "(Author) said (Excerpt)"
msgstr "(Autor) dijo (Extracto)"

#: post-specific-comments-widget.php:236
msgid "(Excerpt) &ndash; (Author)"
msgstr "(Extracto) &ndash; (Autor)"

#: post-specific-comments-widget.php:237
msgid "(Excerpt)"
msgstr "(Extracto)"

#: post-specific-comments-widget.php:238
msgid "Other format:"
msgstr "Otro formato:"

#: post-specific-comments-widget.php:244
msgid ""
"Use text &amp; shortcodes, no CSS/JS/HTML except &lt;p&gt;, &lt;br /&gt;, "
"&lt;strong&gt;, &lt;ul&gt;, &lt;li&gt;, and &lt;em&gt;."
msgstr ""
"Utilice texto y shortcodes, sin CSS/JS/HTML excepto &lt;p&gt;, &lt;br /&gt;, "
"&lt;strong&gt;, &lt;ul&gt;, &lt;li&gt;, and &lt;em&gt;."

#: post-specific-comments-widget.php:245
msgid "Shortcodes are: [AUTHOR], [TITLE], [EXCERPT], [DATE], [AVATAR]."
msgstr "Los shortcodes son: [AUTHOR], [TITLE], [EXCERPT], [DATE], [AVATAR]."

#: post-specific-comments-widget.php:246
msgid "Refer to plugin readme.txt file for more info."
msgstr ""
"Consulte el archivo readme.txt del plugin para obtener más información."

# @ pscw
#: post-specific-comments-widget.php:249
msgid "Excerpt Length"
msgstr "Longitud del extracto"

# @ pscw
#: post-specific-comments-widget.php:252
msgid "Excerpt Trailing"
msgstr "Excerpt Trailing"

#: post-specific-comments-widget.php:256
#, php-format
msgid ""
"Please support hard working Wordpress developers with <a href=\"%1$s\" "
"target=\"_blank\" rel=\"noopener\">small donations</a> and/or <a href=\"%2$s"
"\" target=\"_blank\" rel=\"noopener\">plugin reviews</a>. Thank you!"
msgstr ""
"Por favor, apoye a los desarrolladores de Wordpress trabajando duro con <a "
"href=\"%1$s\" target=\"_blank\" rel=\"noopener\">pequeñas donaciones</a> y / "
"o comentarios de <a href=\"%2$s\" target=\"_blank\" rel=\"noopener\">plugins."
"</a> ¡Gracias!"

#. Plugin Name of the plugin/theme
msgid "Post-Specific Comments Widget (PSCW)"
msgstr ""

#. Description of the plugin/theme
msgid ""
"A widget that displays recent comments from a *specific post or page* (or "
"all). Display format is highly customizable with shortcodes, hooks, and "
"unique CSS tags, and includes gravatars."
msgstr ""
"Un widget que muestra comentarios recientes de una *publicación o página "
"específica* (o todas). El formato de visualización es altamente "
"personalizable con shortcodes, ganchos y etiquetas CSS únicas, e incluye "
"gravatars."

#. Author of the plugin/theme
msgid "Little Package"
msgstr ""
